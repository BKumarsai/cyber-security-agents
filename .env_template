# ============================================================
#  Cyber Security LLM Agents - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ──────────────────────────────────────────────
# LLM API Keys (choose one or both)
# ──────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here          # optional

# ──────────────────────────────────────────────
# MITRE Caldera Settings
# ──────────────────────────────────────────────
CALDERA_URL=http://localhost:8888
CALDERA_API_KEY=ADMIN123                          # default Caldera admin key

# ──────────────────────────────────────────────
# Internal Servers
# ──────────────────────────────────────────────
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080

FTP_SERVER_HOST=0.0.0.0
FTP_SERVER_PORT=2121

# ──────────────────────────────────────────────
# Agent Settings
# ──────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile                 # or gpt-4o etc.
MAX_ITERATIONS=10                                 # max agent loop iterations
LOG_LEVEL=INFO                                    # DEBUG | INFO | WARNING | ERROR
